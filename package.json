    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@types/leaflet": "^1.9.8",
    "@types/pg": "^8.20.0",
    "ai": "^6.0.185",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "express": "^4.22.2",
    "framer-motion": "^12.39.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
